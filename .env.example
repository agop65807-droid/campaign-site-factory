# ================================
# Factory Control Plane
# ================================
FACTORY_SUPABASE_URL=https://YOUR-FACTORY-PROJECT.supabase.co
FACTORY_SUPABASE_SERVICE_ROLE_KEY=YOUR_FACTORY_SERVICE_ROLE_KEY
FACTORY_ENCRYPTION_KEY=64_HEX_CHARS_ENCRYPTION_KEY

# ================================
# Tenant Runtime (inside each tenant deployment)
# ================================
SUPABASE_URL=https://YOUR-TENANT-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_TENANT_SERVICE_ROLE_KEY

# ================================
# Provisioning Providers
# ================================
VERCEL_TOKEN=YOUR_VERCEL_TOKEN
VERCEL_TEAM_ID=YOUR_VERCEL_TEAM_ID
SUPABASE_ACCESS_TOKEN=YOUR_SUPABASE_MANAGEMENT_TOKEN
SUPABASE_ORG_ID=YOUR_SUPABASE_ORG_ID

# ================================
# Security
# ================================
FACTORY_REQUIRE_2FA=true
