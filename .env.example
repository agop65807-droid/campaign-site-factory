# ============================================================
# Campaign Site Factory - Environment Variables
# ============================================================
# Copy this to .env.local and fill in the values

# --- Factory Control Plane (for factory.html + api/factory/) ---
FACTORY_SUPABASE_URL=https://your-factory-project.supabase.co
FACTORY_SUPABASE_KEY=your-factory-supabase-anon-key
FACTORY_ENCRYPTION_KEY=your-64-char-hex-encryption-key-for-secrets-vault

# --- Tenant Site (for index.html + admin.html + api/[...path].js) ---
SUPABASE_URL=https://your-tenant-project.supabase.co
SUPABASE_KEY=your-tenant-supabase-anon-key

# --- Admin Credentials (legacy - will be replaced by DB auth) ---
ADMIN_USER=admin
ADMIN_PASS=your-admin-password

# --- Vercel API (for provisioning engine) ---
VERCEL_TOKEN=your-vercel-api-token
VERCEL_TEAM_ID=your-team-id

# --- Supabase Management API (for provisioning engine) ---
SUPABASE_ACCESS_TOKEN=your-supabase-management-api-token
SUPABASE_ORG_ID=your-supabase-org-id
